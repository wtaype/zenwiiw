{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zenwii",
  "version": "11.0.0",
  "identifier": "com.zenwii.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Zenwii",
        "width": 500,
        "height": 900,
        "minWidth": 500,
        "minHeight": 300,
        "resizable": true,
        "center": true,
        "maximized": false,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
